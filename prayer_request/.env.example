# Blocks Network — from dashboard or: blocks login --write-env
BLOCKS_API_KEY=

# YouVersion Platform — https://platform.youversion.com/
YOUVERSION_APP_KEY=

# OpenAI — https://platform.openai.com/
OPENAI_API_KEY=

# Vercel: set OPENAI_API_KEY and YOUVERSION_APP_KEY in Project → Environment Variables.

# Optional
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_USER_TEXT_CHARS=1500
# OPENAI_PASTORAL_MODE=combined
# OPENAI_INCLUDE_REASONING=false
# PROMPTS_DIR=./prompts
# OPENAI_MODERATION_ENABLED=true
